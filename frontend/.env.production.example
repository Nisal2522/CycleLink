# Production env example. For Vercel: set these in Project → Settings → Environment Variables
# (Vercel does not use this file; it uses the dashboard. Copy variable names below.)

# Backend API base URL (required for production — your Render backend, e.g. https://your-app.onrender.com/api)
VITE_API_URL=https://your-app.onrender.com/api

# Optional: same keys as in .env if you need them in production build
# VITE_GOOGLE_MAPS_API_KEY=...
# VITE_GOOGLE_CLIENT_ID=...
